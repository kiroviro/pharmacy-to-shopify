{% assign delivery_method_types = delivery_agreements | map: 'delivery_method_type' | uniq %}
{% if delivery_method_types.size > 1 %}
  {% assign has_split_cart = true %}
{% else %}
  {% assign has_split_cart = false %}
{% endif %}

{% capture email_title %}
  {% if has_pending_payment %}
    Благодарим ви за поръчката.
  {% else %}
    Благодарим ви за покупката!
  {% endif %}
{% endcapture %}
{% capture email_body %}
  {% if has_pending_payment %}
    {% if buyer_action_required %}
      Ще получите потвърждение по имейл, когато направите плащането.
    {% else %}
      Плащането ви се обработва. Ще получите имейл, когато поръчката ви е потвърдена.
    {% endif %}
  {% else %}
    {% if requires_shipping %}
    {% case delivery_method %}
        {% when 'pick-up' %}
          Ще получите имейл, когато поръчката ви е готова за взимане.
        {% when 'local' %}
          Здравейте, {{ customer.first_name }}, подготвяме поръчката ви за доставка.
        {% else %}
          Подготвяме поръчката ви за изпращане. Ще ви известим, когато бъде изпратена.
      {% endcase %}
        {% if delivery_instructions != blank  %}
          <p><b>Информация за доставка:</b> {{ delivery_instructions }}</p>
        {% endif %}
       {% if consolidated_estimated_delivery_time %}
        {% if has_multiple_delivery_methods %}
          <h3 class="estimated_delivery__title">Очаквана доставка</h3>
          <p>{{ consolidated_estimated_delivery_time }}</p>
        {% else %}
          <p>
            Очаквана доставка <b>{{ consolidated_estimated_delivery_time }}</b>
          </p>
        {% endif %}
       {% endif %}
    {% endif %}
  {% endif %}
  {% assign gift_card_line_items = line_items | where: "gift_card" %}
  {% assign found_gift_card_with_recipient_email = false %}
  {% for line_item in gift_card_line_items %}
    {% if line_item.properties["__shopify_send_gift_card_to_recipient"] and line_item.properties["Recipient email"] %}
      {% assign found_gift_card_with_recipient_email = true %}
      {% break %}
    {% endif %}
  {% endfor %}
  {% if found_gift_card_with_recipient_email %}
    <p>Получателят на ваучера за подарък ще получи имейл с кода на ваучера.</p>
  {% elsif gift_card_line_items.first %}
    <p>Ще получите отделни имейли за всички ваучери за подарък.</p>
  {% endif %}
{% endcapture %}

