          {% if line.original_line_price != line.final_line_price %}
            {%- assign _eur = line.original_line_price | divided_by: 1.95583 | round: 0 -%}
            <del class="order-list__item-original-price">€{{ _eur | money_without_currency }} ({{ line.original_line_price | money }} лв.)</del>
          {% endif %}
